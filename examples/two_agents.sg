// Demonstrates agent spawning, state fields, and await
// Two workers compute values that are combined by the main agent

agent Worker {
    value: Int
    multiplier: Int

    on start {
        let result = self.value * self.multiplier;
        emit(str(result));
    }
}

agent Main {
    on start {
        // Spawn two workers with different field values
        let w1 = spawn Worker { value: 10, multiplier: 2 };
        let w2 = spawn Worker { value: 7, multiplier: 3 };

        // Await both results
        let r1 = try await w1;
        let r2 = try await w2;

        // Display the results
        print("Worker 1 result: {r1}");
        print("Worker 2 result: {r2}");

        emit("done");
    }

    on error(e) {
        print("Worker failed");
        emit("error");
    }
}

run Main;
