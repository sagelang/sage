// Full research demo: parallel LLM-powered research agents
// This is the canonical Sage example showing the language's key features:
// - Agents as first-class primitives
// - Agent state (formerly "beliefs")
// - spawn/await for concurrency
// - infer for LLM integration
// - Error handling with try/on error
//
// Run with: sage run examples/research.sg
// (Requires SAGE_API_KEY environment variable, or use --mock for testing)

agent Researcher {
    topic: String

    on start {
        let summary = try infer(
            "Write a concise 2-sentence summary of: {self.topic}"
        );
        emit(summary);
    }

    on error(e) {
        emit("Research unavailable for this topic");
    }
}

agent Coordinator {
    on start {
        print("Starting research on two topics...");

        // Spawn researchers in parallel
        let r1 = spawn Researcher { topic: "quantum computing" };
        let r2 = spawn Researcher { topic: "CRISPR gene editing" };

        // Await results (researchers handle errors internally, so always succeed)
        let s1 = try await r1;
        let s2 = try await r2;

        // Display findings
        print("");
        print("=== Research Results ===");
        print("");
        print("Quantum Computing:");
        print(s1);
        print("");
        print("CRISPR Gene Editing:");
        print(s2);

        emit("Research complete");
    }

    on error(e) {
        print("Research pipeline failed");
        emit("Research failed");
    }
}

run Coordinator;
