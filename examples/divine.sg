// Demonstrates the divine expression for LLM calls
// Run with: sage run examples/divine.sg
// (Requires SAGE_API_KEY environment variable, or use --mock)

agent Main {
    on start {
        let response = try divine("What is 2 + 2? Reply with just the number.");
        print("LLM says: " ++ response);
        yield(response);
    }

    on error(e) {
        print("Error occurred");
        yield("error");
    }
}

run Main;
