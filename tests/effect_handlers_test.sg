// AE-01: Algebraic Effects - Effect Handler Tests
//
// Verify that handler declarations compile and can be assigned to agents

// Effect handler declarations
handler DefaultLLM handles Infer {
    model: "gpt-4o"
    temperature: 0.7
    max_tokens: 1024
}

handler FastLLM handles Infer {
    model: "gpt-4o-mini"
    temperature: 0.3
    max_tokens: 256
}

handler TestLLM handles Infer {
    model: "test-model"
    temperature: 0.0
    max_tokens: 100
}

// Simple agent for testing
agent SimpleWorker {
    on start {
        yield(0);
    }
}

// Supervisor that assigns handlers to children
supervisor TestSupervisor {
    strategy: OneForOne

    children {
        SimpleWorker {
            restart: Temporary
        }
    }
}

// ============================================================================
// Tests - verify syntax compiles
// ============================================================================

test "AE-01a: handler declaration compiles" {
    // DefaultLLM, FastLLM, TestLLM all declared above
    assert_true(true);
}

test "AE-01b: multiple handlers for same effect allowed" {
    // DefaultLLM, FastLLM, and TestLLM all handle Infer
    assert_true(true);
}

test "AE-01c: handler with all config fields compiles" {
    // model, temperature, max_tokens all specified
    assert_true(true);
}

test "AE-01d: supervisor with children compiles" {
    assert_true(true);
}

test "AE-01e: mock infer syntax works" {
    // Just verify mock syntax - can't call infer directly in tests
    mock infer -> "test response";
    assert_true(true);
}
